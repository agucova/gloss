{
	"name": "@gloss-space/cli",
	"version": "0.1.0",
	"description": "Gloss CLI + MCP server: search and list your highlights, bookmarks, and tags from the command line or a local MCP client.",
	"keywords": [
		"annotations",
		"bookmarks",
		"cli",
		"gloss",
		"highlights",
		"mcp",
		"model-context-protocol"
	],
	"homepage": "https://gloss.space",
	"license": "MIT",
	"author": "Agustín Covarrubias",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/agucova/gloss.git",
		"directory": "packages/cli"
	},
	"bin": {
		"gloss": "dist/cli.js",
		"gloss-mcp": "dist/mcp.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"check-types": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.0",
		"@stricli/core": "^1.1.0",
		"chalk": "^5.4.1",
		"cli-table3": "^0.6.5",
		"open": "^10.1.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@gloss/config": "workspace:*",
		"@types/node": "^22.13.4",
		"tsup": "^8.4.0",
		"typescript": "^5.8.2"
	},
	"engines": {
		"node": ">=20"
	}
}
