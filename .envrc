# Enable devenv integration with direnv
# See https://devenv.sh/automatic-shell-activation/

if ! has devenv; then
  echo "devenv not found. Install it from https://devenv.sh/getting-started/"
  exit 1
fi

# Use devenv
eval "$(devenv print-dev-env)"

# Load local overrides (gitignored). Used for secrets like CLOUDFLARE_API_TOKEN
# that shouldn't live in a tracked file. Also picks up the CONVEX_* vars that
# `convex dev` writes to .env.local so they're available in the shell.
dotenv_if_exists .env.local
