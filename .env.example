# ───────────────────────────────────────────────────
# Client env (web + extension)
# ───────────────────────────────────────────────────

# From `bunx convex dev` — also copied into .env.local (do NOT commit .env.local).
VITE_CONVEX_URL=https://<slug>.convex.cloud
VITE_CONVEX_SITE_URL=https://<slug>.convex.site

# Where the extension redirects for login.
VITE_WEB_URL=http://localhost:3001

# Enables the dev impersonation panel on /login. Set only in the dev .env —
# production builds must leave this unset so the panel gets tree-shaken out.
VITE_DEV_IMPERSONATION=true

# ───────────────────────────────────────────────────
# Convex backend env — NOT read from this file.
# Set these on the deployment with `bunx convex env set NAME value`.
# ───────────────────────────────────────────────────
#   BETTER_AUTH_SECRET          min 32 chars, e.g. `openssl rand -base64 32`
#   SITE_URL                    CORS origin for Better-Auth routes (e.g. http://localhost:3001)
#   GOOGLE_CLIENT_ID            (optional) Google OAuth
#   GOOGLE_CLIENT_SECRET        (optional)
#   APPLE_CLIENT_ID             (optional) Apple OAuth
#   APPLE_CLIENT_SECRET         (optional)
#   RESEND_API_KEY              (optional) magic-link email sender
#   EMAIL_FROM                  (optional) e.g. "Gloss <noreply@yourdomain>"
